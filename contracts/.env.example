# Persistent Anvil state lives in .persistent-chain/ (can grow to many GB). Reset: npm run local:chain:reset (repo root).
# Explorer/API against a real node: set server/.env RPC_URL + DATABASE_URL — use npm run local:stack (no local Anvil needed).
# npm run node sets HARDHAT_NODE_INTERVAL_MS (empty blocks ~3s + automine). Override: HARDHAT_NODE_INTERVAL_MS=5000
# Persistent Anvil: empty blocks every N sec (script default 3). ANVIL_BLOCK_TIME_SEC=0 = tx-only mining
# Disk state save interval (default 30s if unset — so short runs still resume). Script raises minimum when state file is huge.
# ANVIL_STATE_INTERVAL_SEC=30
# ANVIL_STATE_INTERVAL_MAX_CAP_SEC=604800
# ANVIL_STATE_FULL_PARSE_MAX_MB=512
# ANVIL_BAK_POLL_MS=500
# ANVIL_BAK_STABLE_MS=4000
DEPLOYER_PRIVATE_KEY=0x...
# Optional: native transfer to any RPC (npm run send-native:rpc) — uses DEPLOYER_PRIVATE_KEY if PRIVATE_KEY unset
PRIVATE_KEY=
RECIPIENT=
# Local JSON-RPC (Hardhat, Anvil persistent, or Geth): default port 8545
PETH_RPC_URL=http://50.28.84.113:8545
PETH_CHAIN_ID=4111
RPC_URL=http://50.28.84.113:8545
SEND_AMOUNT=1
# SEND_ALL=1
# Native ECNA top-up from npm run fund:treasury (preferred; matches server ECNA_NATIVE_MINT_ADDRESS)
ECNA_NATIVE_MINT_ADDRESS=0x...
TREASURY_ADDRESS=0x...
ADMIN_ADDRESS=0x...
PETH_TESTNET_RPC=https://...
PETH_TESTNET_CHAIN_ID=133713
PETH_MAINNET_RPC=https://...
PETH_MAINNET_CHAIN_ID=133714
PETH_EXPLORER_API_KEY=dummy
PETH_EXPLORER_API_URL=http://50.28.84.113:4000/api/verify/etherscan
PETH_EXPLORER_BROWSER_URL=http://50.28.84.113:5174
