# Microsoft SQL Server. Special chars in password: use braces, e.g. password={p@ss#word}
# encrypt=true; trustServerCertificate=true is typical for private servers / self-signed TLS.
DATABASE_URL="sqlserver://YOUR_HOST:1433;database=YOUR_DB;user=YOUR_USER;password={YOUR_PASSWORD};encrypt=true;trustServerCertificate=true"
# Optional pool tuning (appended automatically if omitted from DATABASE_URL). Raise if you see
# "Timed out fetching a new connection from the connection pool" under load (api + indexer).
# PRISMA_CONNECTION_LIMIT=25
# PRISMA_POOL_TIMEOUT_SEC=60
# After rotating the SQL password: update DATABASE_URL here, then restart api and indexer — "Login failed for user" means bad credentials.
PORT=4000
RPC_URL=https://rpc.ecnascan.com
# Validator + gas (explorer blocks > 0); must match Clique signer / miner-private.hex
ECNA_PRIMARY_ADDRESS=
# Comma-separated Clique signers (genesis ECNA_VALIDATORS + /api/v1/config validators list)
ECNA_VALIDATORS=
# Premine / treasury (optional; else treasury = primary)
ECNA_NATIVE_MINT_ADDRESS=
# Optional overrides if ECNA_PRIMARY_ADDRESS is unset:
CLIQUE_SIGNER_ADDRESS=
GENESIS_COINBASE_ADDRESS=
# ECNA L1 (Geth ecnachain) default; use 31337 for Hardhat-only dev
RPC_CHAIN_ID=4111
CHAIN_ID=4111
NATIVE_SYMBOL=ECNA
NATIVE_NAME=E Canna
PETH_TOKEN_ADDRESS=
INDEXER_POLL_MS=3000
# Blocks indexed per poll when catching up (default 32). Raise on fast chains / beefy SQL.
INDEXER_BATCH_SIZE=32
# 1 = write GasSnapshot every block (NOT recommended at 90M+ scale — duplicates Block.gasUsed)
# INDEXER_GAS_SNAPSHOTS=0
# 1 = first run: do not backfill — only index blocks after current RPC tip (clean home for "new chain" dev)
INDEXER_START_AT_HEAD=
# First block number to index when backfilling (default 0). Ignored when INDEXER_START_AT_HEAD=1
INDEXER_MIN_BLOCK=
# 1 = on indexer process start only: wipe Block/Transaction tables + indexer cursor (remove after one run)
INDEXER_RESET_ONCE=
# 1 = disable RPC vs index checks (ghost blocks, genesis/cursor hash). Not recommended for production.
INDEXER_SKIP_RPC_RECONCILE=
CORS_ORIGIN=https://dashboard.ecnascan.com,https://explorer.ecnascan.com,https://ecnascan.com
# Required in production (NODE_ENV=production) — comma-separated browser origins
# API rate limit (per IP per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
# 1 = run lowercase address migration on API start (one-off); off by default in production
# NORMALIZE_ADDRESSES_ON_START=0
# Website register/login (JWT in httpOnly cookie). Required in production; dev falls back to an insecure default.
SITE_AUTH_SECRET=
# Set to 1 when the API is served over HTTPS so the session cookie is Secure + SameSite=None (cross-site if needed).
SITE_AUTH_COOKIE_SECURE=
# Public explorer URL (no trailing slash) — returned in /api/v1/config as explorerUrl
EXPLORER_PUBLIC_URL=https://explorer.ecnascan.com
# info = verbose; warn/error quieter. HTTP success requests are never logged (see pinoHttp customLogLevel).
LOG_LEVEL=info
NODE_ENV=production

# Website register/login table (creates dbo.SiteUser if missing):
#   npm run db:apply-site-user -w server

# --- Production (SQL Server) ---
# After deploy: npm run db:migrate:deploy -w server
# If this database was first created with "prisma db push" (tables already exist), baseline once:
#   npx prisma migrate resolve --applied 20260209000000_init_sqlserver
# SQL backups: schedule full backups of Db_* on the server; indexer can be rebuilt from RPC if needed.
# Chain truth = Geth RPC, not this DB. Keep INDEXER_SKIP_RPC_RECONCILE unset (0) so index matches chain after rollbacks.
